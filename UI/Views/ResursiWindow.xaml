<Window x:Class="CoWorkingManager.UI.Views.ResursiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Resursi"
        Height="400"
        Width="500"
        Closed="ResursiWindow_Closed">

<Grid Margin="10">

        <StackPanel>

            <TextBlock x:Name="NazivLanca"
                       Text="CoWorking Manager"
                       FontSize="22"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       Margin="0 0 0 30"/>

            <DataGrid x:Name="ResursiGrid"
                      AutoGenerateColumns="True"
                      Margin="0 0 0 50"/>

        </StackPanel>

        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Right">

            <Button Content="Dodaj" Width="100" Margin="5"/>
            <Button Content="Izmeni" Width="100" Margin="5"/>
            <Button Content="Obriši" Width="100" Margin="5"/>

        </StackPanel>

    </Grid>
</Window>
<Window x:Class="CoWorkingManager.UI.Views.GlavniWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard"
        Height="400"
        Width="500">

    <Grid Margin="20">

        <UniformGrid Rows="3" Columns="2">

            <Button Content="Users"
                    Click="Users_Click"/>

            <Button Content="Locations"
                    Click="Locations_Click"/>

            <Button Content="Membership Types"
                    Click="Membership_Click"/>

            <Button Content="Resources"
                    Click="Resources_Click"/>

            <Button Content="Reservations"
                    Click="Reservations_Click"/>

        </UniformGrid>

    </Grid>

</Window>
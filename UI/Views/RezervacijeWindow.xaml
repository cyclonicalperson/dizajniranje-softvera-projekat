<Window x:Class="CoWorkingManager.UI.Views.RezervacijeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rezervacije"
        Height="650"
        Width="1000"
        Background="#F4F6F9">

    <Grid Margin="20">

        <StackPanel>

            <TextBlock x:Name="Lanac"
                       FontSize="22"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       Margin="0 0 0 20"/>

            <!-- Navigacija -->

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0 0 0 10">

                <Button Content="Pretraga po korisniku"
                        Width="180"
                        Margin="5"
                        Click="PretragaKorisnik_Click"/>

                <Button Content="Pretraga po danu/lokaciji"
                        Width="200"
                        Margin="5"
                        Click="PretragaDanLokacija_Click"/>

                <Button Content="Kreiraj/Izmeni"
                        Width="150"
                        Margin="5"
                        Click="KreirajIzmeni_Click"/>

                <Button Content="Glavni Meni"
                        Width="120"
                        Margin="5"
                        Click="GlavniMeni_Click"/>

            </StackPanel>

            <!-- PRETRAGA PO KORISNIKU -->

            <StackPanel x:Name="PretragaKorisnik"
                        Visibility="Collapsed">

                <ComboBox x:Name="SelRezervacije_KorisnikCBox"
                          Width="200"
                          Margin="5"
                          SelectionChanged="SelRezervacije_KorisnikCBox_SelectionChanged"/>

                <DataGrid x:Name="TabelaRezervacijaKorisnik"
                          Height="350"
                          AutoGenerateColumns="False"
                          IsReadOnly="True">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Resurs" Binding="{Binding Resurs.Ime}"/>
                        <DataGridTextColumn Header="Lokacija" Binding="{Binding Lokacija}"/>
                        <DataGridTextColumn Header="Početak" Binding="{Binding PocetakVreme}"/>
                        <DataGridTextColumn Header="Završetak" Binding="{Binding KrajVreme}"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding StatusRezervacije}"/>

                    </DataGrid.Columns>

                </DataGrid>

            </StackPanel>

            <!-- PRETRAGA PO DANU/LOKACIJI -->

            <StackPanel x:Name="PretragaDanLokacija"
                        Visibility="Collapsed">

                <StackPanel Orientation="Horizontal"
                            Margin="0 0 0 10">

                    <DatePicker x:Name="SelRezervacije_Dan"
                                Width="200"
                                Margin="5"/>

                    <ComboBox x:Name="SelRezervacije_LokacijaCBox"
                              Width="200"
                              Margin="5"/>

                    <Button Content="Pretraži"
                            Width="120"
                            Margin="5"
                            Click="PretraziDanLokacija_Click"/>

                </StackPanel>

                <DataGrid x:Name="TabelaRezervacijaDanLokacija"
                          Height="350"
                          AutoGenerateColumns="False"
                          IsReadOnly="True">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Korisnik" Binding="{Binding Korisnik.Ime}"/>
                        <DataGridTextColumn Header="Resurs" Binding="{Binding Ime}"/>
                        <DataGridTextColumn Header="Početak" Binding="{Binding PocetakVreme}"/>
                        <DataGridTextColumn Header="Završetak" Binding="{Binding KrajVreme}"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding StatusRezervacije}"/>

                    </DataGrid.Columns>

                </DataGrid>

            </StackPanel>

            <!-- Status -->

            <TextBlock x:Name="Uspesno"
                       Foreground="Green"
                       FontWeight="Bold"
                       Visibility="Collapsed"
                       TextAlignment="Center"
                       Margin="10">
                Akcija uspešno izvršena
            </TextBlock>

            <TextBlock x:Name="Neuspesno"
                       Foreground="Red"
                       FontWeight="Bold"
                       Visibility="Collapsed"
                       TextAlignment="Center">
                Nije moguće izvršiti akciju
            </TextBlock>

        </StackPanel>

    </Grid>

</Window>
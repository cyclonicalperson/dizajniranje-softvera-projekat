        <ComboBox Name="SelKorisnici_StatusCBox" Width="150" Height="25" SelectionChanged="SelKorisnici_StatusCBox_SelectionChanged" Margin="165,10,445,509"/>

        <ListBox ItemsSource="{Binding People}" DisplayMemberPath="FirstName" Margin="10,40,650,504"/>
        <ListBox ItemsSource="{Binding People}" DisplayMemberPath="FirstName" Margin="110,40,550,504"/>

        <Button Width="100" Height="25"

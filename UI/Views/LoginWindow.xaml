<Window x:Class="CoWorkingManager.UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login"
        Height="350"
        Width="350"
        Background="#F4F6F9">

    <Grid>

        <Border Background="White"
                CornerRadius="10"
                Padding="30"
                Margin="5">

            <StackPanel>

                <TextBlock Text="CoWorking Manager"
                           FontSize="22"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Margin="0 0 0 30"/>

                <TextBlock Text="Username"/>
                <TextBox x:Name="UsernameBox"
                         Height="30"
                         Margin="0 5 0 15"/>

                <TextBlock Text="Password"/>
                <PasswordBox x:Name="PasswordBox"
                             Height="30"
                             Margin="0 5 0 20"/>

                <Button Content="Login"
                        Height="35"
                        FontSize="14"
                        Click="Login_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>
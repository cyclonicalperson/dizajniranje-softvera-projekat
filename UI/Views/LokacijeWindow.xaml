<Window x:Class="CoWorkingManager.UI.Views.LokacijeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lokacije"
        Height="650"
        Width="1000"
        Background="#F4F6F9">

    <Grid Margin="20">

        <StackPanel>

            <TextBlock x:Name="Lanac"
                       FontSize="22"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       Margin="0 0 0 20"/>

            <!-- Navigacija -->

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0 0 0 10">

                <Button Content="Pretraga"
                        Width="120"
                        Margin="5"
                        Click="Pretraga_Click"/>

                <Button Content="Izmena podataka"
                        Width="150"
                        Margin="5"
                        Click="Izmena_Click"/>

                <Button Content="Glavni Meni"
                        Width="120"
                        Margin="5"
                        Click="GlavniMeni_Click"/>

            </StackPanel>

            <!-- PRETRAGA -->

            <StackPanel x:Name="Pretraga"
                        Visibility="Collapsed">

                <DataGrid x:Name="TabelaLokacija"
                          Height="350"
                          AutoGenerateColumns="False"
                          IsReadOnly="True">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Naziv" Binding="{Binding Lokacija.Ime}"/>
                        <DataGridTextColumn Header="Adresa" Binding="{Binding Lokacija.Adresa}"/>
                        <DataGridTextColumn Header="Grad" Binding="{Binding Lokacija.Grad}"/>
                        <DataGridTextColumn Header="Radno vreme" Binding="{Binding Lokacija.RadniSati}"/>
                        <DataGridTextColumn Header="Maks. kapacitet" Binding="{Binding Lokacija.MaxBrojKorisnika}"/>
                        <DataGridTextColumn Header="Broj radnih mesta" Binding="{Binding UkupnoResursa}"/>
                        <DataGridTextColumn Header="Rezervisanih" Binding="{Binding ZauzetihResursa}"/>
                        <DataGridTextColumn Header="Zauzetost (%)" Binding="{Binding ProcenatZauzetosti}"/>

                    </DataGrid.Columns>

                </DataGrid>

            </StackPanel>

            <!-- IZMENA -->

            <StackPanel x:Name="Izmena"
                        Visibility="Collapsed">

                <Grid Margin="0 10">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition/>
                        <ColumnDefinition/>

                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>

                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>

                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="5">
                        <TextBlock Text="Naziv lokacije:"/>
                        <TextBox x:Name="TextBoxNazivLokacije"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="5">
                        <TextBlock Text="Adresa:"/>
                        <TextBox x:Name="TextBoxAdresa"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="5">
                        <TextBlock Text="Grad:"/>
                        <TextBox x:Name="TextBoxGrad"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="5">
                        <TextBlock Text="Radno vreme:"/>
                        <TextBox x:Name="TextBoxRadnoVreme"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="5">
                        <TextBlock Text="Maksimalan kapacitet:"/>
                        <TextBox x:Name="TextBoxMaksimalanKapacitet"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="5">
                        <TextBlock Text="Opis:"/>
                        <TextBox x:Name="TextBoxOpis"/>
                    </StackPanel>

                </Grid>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <Button Content="Dodaj"
                            Width="120"
                            Margin="10"
                            Click="Dodaj_Click"/>

                    <Button Content="Izmeni"
                            Width="120"
                            Margin="10"
                            Click="Izmeni_Click"/>

                    <Button Content="Obriši"
                            Width="120"
                            Margin="10"
                            Click="Obrisi_Click"/>

                </StackPanel>

            </StackPanel>

            <!-- Status -->

            <TextBlock x:Name="Uspesno"
                       Foreground="Green"
                       FontWeight="Bold"
                       Visibility="Collapsed"
                       TextAlignment="Center"
                       Margin="10">
                Akcija uspešno izvršena
            </TextBlock>

            <TextBlock x:Name="Neuspesno"
                       Foreground="Red"
                       FontWeight="Bold"
                       Visibility="Collapsed"
                       TextAlignment="Center">
                Nije moguće izvršiti akciju
            </TextBlock>

        </StackPanel>

    </Grid>

</Window>
<Window x:Class="CoWorkingManager.UI.Views.RezervacijeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rezervacija"
        Height="400"
        Width="400"
        Background="#F4F6F9">

    <Grid Margin="20">

        <StackPanel>

            <Label Content="Korisnik:"/>
            <ComboBox x:Name="ComboKorisnik"/>

            <Label Content="Lokacija:"/>
            <ComboBox x:Name="ComboLokacija"/>

            <Label Content="Resurs:"/>
            <ComboBox x:Name="ComboResurs"/>

            <StackPanel x:Name="PanelBrojUcesnika" Visibility="Collapsed">
                <Label Content="Broj učesnika (za sale):"/>
                <TextBox x:Name="TxtBrojUcesnika"/>
            </StackPanel>

            <Label Content="Datum i vreme početka:"/>
            <DatePicker x:Name="DatePocetak" DisplayDateStart="{Binding Path=Today}"/>

            <Label Content="Datum i vreme završetka:"/>
            <DatePicker x:Name="DateZavrsetak" DisplayDateStart="{Binding Path=Today}"/>

            <TextBlock x:Name="ValidationError" Foreground="Red" Visibility="Collapsed" TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 20 0 0">
                <Button x:Name="BtnSacuvaj" Content="Sačuvaj" Width="100" Margin="5" Click="Sacuvaj_Click"/>
                <Button x:Name="BtnOtkaziRezervaciju" Content="Otkazi rezervaciju" Width="150" Margin="5" Visibility="Collapsed" Click="OtkaziRezervaciju_Click"/>
                <Button Content="Zatvori" Width="100" Margin="5" Click="Zatvori_Click"/>
            </StackPanel>

        </StackPanel>

    </Grid>

</Window>
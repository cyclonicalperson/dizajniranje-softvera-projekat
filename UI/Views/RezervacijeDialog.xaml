<Window x:Class="CoWorkingManager.UI.Views.RezervacijeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kreiraj/Izmeni rezervaciju"
        Height="400"
        Width="500"
        Background="#F4F6F9">

    <Grid Margin="20">

        <StackPanel>

            <TextBlock Text="Korisnik:" Margin="0 0 0 5"/>
            <ComboBox x:Name="ComboKorisnik" Margin="0 0 0 10"/>

            <TextBlock Text="Resurs:" Margin="0 0 0 5"/>
            <ComboBox x:Name="ComboResurs" Margin="0 0 0 10"/>

            <TextBlock Text="Lokacija:" Margin="0 0 0 5"/>
            <ComboBox x:Name="ComboLokacija" Margin="0 0 0 10"/>

            <TextBlock Text="Datum i vreme početka:" Margin="0 0 0 5"/>
            <DatePicker x:Name="DatePocetak" Margin="0 0 0 10" DisplayDate="{Binding DatumPocetka}" />

            <TextBlock Text="Datum i vreme završetka:" Margin="0 0 0 5"/>
            <DatePicker x:Name="DateZavrsetak" Margin="0 0 0 10" DisplayDate="{Binding DatumZavrsetka}" />

            <StackPanel x:Name="PanelBrojUcesnika" Visibility="Collapsed">
                <TextBlock Text="Broj učesnika (za sale):" Margin="0 0 0 5"/>
                <TextBox x:Name="TextBrojUcesnika" Margin="0 0 0 10" />
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <Button Content="Sačuvaj"
                        Width="120"
                        Margin="10"
                        Click="Sacuvaj_Click"/>

                <Button Content="Otkaži"
                        Width="120"
                        Margin="10"
                        Click="Otkazi_Click"/>

            </StackPanel>

        </StackPanel>

    </Grid>

</Window>